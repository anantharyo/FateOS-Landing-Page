---
// src/components/Header.astro - Sticky Cosmic Navigation
import { siteConfig } from '../config/site';
---

<header class="fixed top-0 w-full z-50 transition-all duration-300 cosmic-reveal" id="site-header">
  <nav class="cosmic-glass border-b border-cosmic-border backdrop-blur-lg">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-gradient-cosmic-orange rounded-lg flex items-center justify-center cosmic-glow">
            <span class="cosmic-body text-white font-bold text-lg">⚡</span>
          </div>
          <span class="cosmic-heading text-cosmic-text">Fate OS</span>
        </a>
        
        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-8">
          {siteConfig.nav.links.map((link) => (
            <a 
              href={link.href} 
              class="cosmic-body text-cosmic-text-muted hover:text-cosmic-text transition-colors duration-200 relative group"
            >
              {link.label}
              <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-cosmic-accent transition-all duration-300 group-hover:w-full"></span>
            </a>
          ))}
          
          <!-- CTA Button -->
          <a href={siteConfig.nav.cta.href} class="cosmic-btn cosmic-btn-primary">
            {siteConfig.nav.cta.label}
          </a>
        </div>
        
        <!-- Mobile Menu Button -->
        <button class="md:hidden cosmic-btn cosmic-btn-secondary" id="mobile-menu-button">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      
      <!-- Mobile Menu -->
      <div class="md:hidden cosmic-reveal mobile-menu-closed" id="mobile-menu">
        <div class="py-4 space-y-4 border-t border-cosmic-border mt-4">
          {siteConfig.nav.links.map((link) => (
            <a 
              href={link.href} 
              class="cosmic-body text-cosmic-text-muted hover:text-cosmic-text block py-3 px-4 transition-colors cosmic-glass-card rounded-lg"
            >
              {link.label}
            </a>
          ))}
          <a href={siteConfig.nav.cta.href} class="cosmic-btn cosmic-btn-primary w-full justify-center py-3">
            {siteConfig.nav.cta.label}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Header scroll effects */
  .header-scrolled {
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(20px);
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }
  
  /* Mobile menu animations */
  .mobile-menu-open {
    max-height: 300px;
    opacity: 1;
  }
  
  .mobile-menu-closed {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
  }
</style>

<script>
  import { animate } from 'motion';
  
  // Header scroll behavior
  let lastScrollY = window.scrollY;
  let headerHidden = false;
  const header = document.getElementById('site-header');
  
  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;
    const scrolledDown = currentScrollY > lastScrollY;
    const pastThreshold = currentScrollY > 100;
    
    if (scrolledDown && pastThreshold && !headerHidden) {
      animate(header, { y: '-100%' }, { duration: 0.3, easing: "ease-in" });
      headerHidden = true;
    } else if (!scrolledDown && headerHidden) {
      animate(header, { y: '0%' }, { duration: 0.3, easing: "ease-out" });
      headerHidden = false;
    }
    
    // Add scrolled class for background change
    if (currentScrollY > 50) {
      header?.classList.add('header-scrolled');
    } else {
      header?.classList.remove('header-scrolled');
    }
    
    lastScrollY = currentScrollY;
  }, { passive: true });
  
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    menuButton?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('mobile-menu-open');
      
      if (isOpen) {
        animate(mobileMenu, { opacity: [1, 0], height: ['auto', 0] }, { duration: 0.3 })
          .then(() => {
            mobileMenu?.classList.remove('mobile-menu-open');
            mobileMenu?.classList.add('mobile-menu-closed', 'hidden');
          });
      } else {
        mobileMenu?.classList.remove('mobile-menu-closed', 'hidden');
        mobileMenu?.classList.add('mobile-menu-open');
        animate(mobileMenu, { opacity: [0, 1], height: [0, 'auto'] }, { duration: 0.3 });
      }
    });
  });
  
  // Smooth scrolling for anchor links
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') || '');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  });
</script>